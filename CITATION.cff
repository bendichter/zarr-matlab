    given-names: Benjamin
    email: ben.dichter@gmail.com
    affiliation: CatalystNeuro
license: MIT
repository-code: "https://github.com/catalystneuro/zarr-matlab"
url: "https://catalystneuro.github.io/zarr-matlab/"
version: 0.3.1
date-released: "2026-07-05"
keywords:
  - Zarr
  - MATLAB
  - array storage
  - compression
  - chunked arrays
  - scientific data
  - cloud storage
